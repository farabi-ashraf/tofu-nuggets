{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tofu Nuggets",
  "version": "0.3.0",
  "identifier": "com.tofunuggets.app",
  "build": {
    "beforeBuildCommand": "npm --prefix ../ui run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/farabi-ashraf/tofu-nuggets/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhENzAyREMxRUEyMTVEN0QKUldSOVhTSHF3UzF3aldzVTN2WW1oQjRqVGpPb21OYWxUKy9TcTJsQXVlWHJLR2dhOWpkbjhTcisK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "Tofu Nuggets",
    "shortDescription": "Hover notes for your desktop icons",
    "longDescription": "Hover over a desktop file or folder to see the note you left on it. Rich text nuggets with todos and file links, created with a global hotkey, stored beside your files.",
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
